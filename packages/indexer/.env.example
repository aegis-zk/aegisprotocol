# AEGIS Indexer Configuration
# Copy to .env and customize as needed

# Server port (default: 4200)
PORT=4200

# Chain ID: 8453 = Base Mainnet, 84532 = Base Sepolia
CHAIN_ID=8453

# RPC endpoint (default: public Base RPC)
RPC_URL=https://mainnet.base.org

# SQLite database file path
DB_PATH=./aegis-indexer.db

# Block polling interval in milliseconds (default: 5000)
POLL_INTERVAL_MS=5000
