# ── AEGIS Audit Queue Configuration ──────────────────────────
# Required
AEGIS_PRIVATE_KEY=0x...              # Auditor wallet private key (signs attestation txs)

# Chain
CHAIN_ID=8453                        # Base L2 (default)
RPC_URL=https://mainnet.base.org     # RPC endpoint

# Queue
QUEUE_DB_PATH=./audit-queue.db       # SQLite database path
POLL_INTERVAL_MS=5000                # Event polling interval
MAX_CONCURRENCY=1                    # Tasks processed in parallel (1 = serial, avoids nonce collisions)
AUDIT_LEVEL=1                        # Default audit level: 1=Functional, 2=Robust, 3=Security

# ZK Proving
CIRCUITS_DIR=../circuits             # Path to noir circuit artifacts

# Retry
RETRY_MAX_ATTEMPTS=5                 # Max retries for failed tasks
RETRY_BASE_DELAY_MS=2000             # Base delay for exponential backoff

# Optional
GAS_LIMIT=                           # Override gas limit (leave empty for auto)
START_BLOCK=                         # Block to start syncing from (leave empty for deployment block)
